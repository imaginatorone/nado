# === Nado Platform Environment Configuration ===
# Copy this file to .env and fill in real values.

# --- Database ---
POSTGRES_DB=nado
POSTGRES_USER=nado_user
POSTGRES_PASSWORD=nado_secret

# --- Auth Mode ---
# "legacy" = self-issued JWT (transitional)
# "keycloak" = Keycloak OAuth2 Resource Server (target)
AUTH_MODE=legacy

# --- Legacy JWT (used only when AUTH_MODE=legacy) ---
JWT_SECRET=ПОМЕНЯЙ_МЕНЯ_НА_64СИМВОЛЬНЫЙ_КЛЮЧ

# --- Keycloak (used when AUTH_MODE=keycloak) ---
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin
KEYCLOAK_ISSUER=http://localhost:8180/realms/nado
KEYCLOAK_JWK=http://localhost:8180/realms/nado/protocol/openid-connect/certs
KEYCLOAK_PUBLIC_URL=http://localhost:8180

# --- Google IdP via Keycloak ---
# Получить в Google Cloud Console: https://console.cloud.google.com/apis/credentials
# Требуется: OAuth 2.0 Client ID (тип: Web application)
# Redirect URI в Google Console: http://localhost:8180/realms/nado/broker/google/endpoint
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Admin Bootstrap (only for dev, seed-enabled=false by default) ---
ADMIN_EMAIL=admin@nado.ru
ADMIN_PASSWORD=N@d0_Adm!n_2026
ADMIN_SEED_ENABLED=false

# --- File Upload ---
UPLOAD_DIR=./uploads

# --- CORS ---
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# --- Email Notifications (Spring Mail) ---
# Включить email-канал уведомлений
MAIL_ENABLED=false
MAIL_FROM=noreply@nado.ru
# SMTP-сервер
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_AUTH=true
SMTP_STARTTLS=true
